# --- Resend (연락 폼) ---
# https://resend.com/api-keys
RESEND_API_KEY=

CONTACT_TO_EMAIL=
# 예: Portfolio <mail@yourdomain.com>  (Resend에서 도메인 인증 필요)
CONTACT_FROM_EMAIL=

# --- Supabase (추후 DB 등) ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 배포(Vercel): 위 변수를 로컬 .env와 동일하게
# Project → Settings → Environment Variables에 넣고 재배포하세요.

# (선택) CORS — 기본은 프로덕션 도메인 + 로컬. 프리뷰 URL 등 추가 시 쉼표로 구분
# CORS_ALLOWED_ORIGINS=https://xxx.vercel.app
