#!/bin/sh
# Removes tool-injected commit message footers (e.g. "Made with Cursor").
msg_file=${1:?}
[ -f "$msg_file" ] || exit 0

perl -i -ne '
  print unless
    /^made-with:/i
    || (/made with/i && /cursor/i)
    || (/made-with/i && /cursor/i)
    || (/generated by/i && /cursor/i)
    || (/^co-authored-by:/i && /cursor/i);
' "$msg_file"
